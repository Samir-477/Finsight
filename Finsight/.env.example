# ============================================================
# FinSight Backend — copy this to Finsight/.env and fill in your keys
# ============================================================

# ---- MAIN LLM (Groq — free at console.groq.com) -----------
DS_MODEL_NAME="llama-3.3-70b-versatile"
DS_API_KEY="your_groq_api_key_here"
DS_BASE_URL="https://api.groq.com/openai/v1"

WRITER_MODEL_NAME="llama-3.3-70b-versatile"
WRITER_API_KEY="your_groq_api_key_here"
WRITER_BASE_URL="https://api.groq.com/openai/v1"

# ---- VLM (Google Gemini — free at aistudio.google.com) ----
VLM_MODEL_NAME="gemini-2.5-flash"
VLM_API_KEY="your_gemini_api_key_here"
VLM_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"

# ---- EMBEDDINGS (local — no key needed) --------------------
EMBEDDING_MODEL_NAME="all-MiniLM-L6-v2"
EMBEDDING_API_KEY=""
EMBEDDING_BASE_URL=""

# ---- WEB SEARCH (Serper — free tier at serper.dev) ---------
SERPER_API_KEY="your_serper_api_key_here"
USE_DUCKDUCKGO="false"

# ---- SEC FILINGS (free — just use your email) --------------
SEC_USER_AGENT="your@email.com"

# ---- MACRO DATA (FRED — free at fred.stlouisfed.org) -------
FRED_API_KEY="your_fred_api_key_here"

# ---- SERVER ------------------------------------------------
PORT=8000
CORS_ORIGINS="http://localhost:3000"
OUTPUT_DIR="./Finsight/outputs"
CHECKPOINT_DIR="./Finsight/checkpoints"
