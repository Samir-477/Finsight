# ============================================================
# FinSight Frontend — copy this to .env.local and fill in values
# ============================================================

# Your deployed backend URL (no trailing slash)
# For local dev:
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# For production (replace with your actual Render backend URL):
# NEXT_PUBLIC_API_URL=https://finsight-backend.onrender.com
# NEXT_PUBLIC_WS_URL=wss://finsight-backend.onrender.com
